# =============================================================================
# History
# =============================================================================
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt append_history hist_ignore_dups share_history

# =============================================================================
# Homebrew (inline — avoids `brew shellenv` subprocess at startup)
# =============================================================================
for _brew_prefix in /home/linuxbrew/.linuxbrew /opt/homebrew /usr/local; do
  if [[ -x "$_brew_prefix/bin/brew" ]]; then
    export HOMEBREW_PREFIX="$_brew_prefix"
    export HOMEBREW_CELLAR="$_brew_prefix/Cellar"
    export HOMEBREW_REPOSITORY="$_brew_prefix/Homebrew"
    fpath=("$_brew_prefix/share/zsh/site-functions" $fpath)
    path=("$_brew_prefix/bin" "$_brew_prefix/sbin" $path)
    export INFOPATH="$_brew_prefix/share/info${INFOPATH:+:$INFOPATH}"
    break
  fi
done
unset _brew_prefix

# =============================================================================
# Completions (cached: rebuild .zcompdump only if older than 24h)
# =============================================================================
autoload -Uz compinit
() {
  setopt local_options extended_glob
  if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qNmh+24) ]]; then
    compinit
  else
    compinit -C
  fi
}

# =============================================================================
# PATH
# =============================================================================
typeset -U path
path=("$HOME/.local/bin" $path)
[[ -d "$HOME/.cargo/bin" ]] && path=("$HOME/.cargo/bin" $path)

# WSL: full Windows PATH inherit is off (see /etc/wsl.conf) — re-add only
# the Windows binaries we actually use, and point the WSL-side Claude CLI
# at its own personal config dir.
if grep -qiE "(microsoft|wsl)" /proc/version 2>/dev/null; then
  for _wp in \
    "/mnt/c/Users/$USER/AppData/Local/Programs/Microsoft VS Code/bin" \
    "/mnt/c/Program Files/Microsoft VS Code/bin"; do
    [[ -d $_wp ]] && path+=("$_wp")
  done
  unset _wp
  export CLAUDE_CONFIG_DIR="$HOME/.claude-personal"
fi

export PATH

# =============================================================================
# Prompt — Starship
# =============================================================================
eval "$(starship init zsh)"

# =============================================================================
# Smart cd — zoxide (drop-in replacement for cd)
# =============================================================================
eval "$(zoxide init --cmd cd zsh)"

# =============================================================================
# fzf — cached init (regenerate after fzf upgrade: fzf --zsh > ~/.cache/zsh/fzf-init.zsh)
# =============================================================================
[[ -d ~/.fzf/bin ]] && path+=(~/.fzf/bin)
if (( $+commands[fzf] )); then
  [[ -f ~/.cache/zsh/fzf-init.zsh ]] || { mkdir -p ~/.cache/zsh; fzf --zsh > ~/.cache/zsh/fzf-init.zsh; }
  source ~/.cache/zsh/fzf-init.zsh
fi

# =============================================================================
# zsh-autosuggestions (covers Debian/Ubuntu, Arch, manual install)
# =============================================================================
for f in \
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh \
  ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh; do
  if [[ -f $f ]]; then
    source "$f"
    break
  fi
done

# =============================================================================
# Terminal window title — show current directory
# Only on cd (chpwd) + once at startup, so apps (Claude Code, vim, ssh) keep theirs
# =============================================================================
function set_win_title() {
  print -Pn "\e]0;${PWD/#$HOME/~}\a"
}
chpwd_functions+=(set_win_title)
set_win_title

# =============================================================================
# Aliases
# =============================================================================

# Navigation
alias c='clear'
alias ..='cd ..'
alias ...='cd ../..'
alias repos='cd ~/Repos'
alias cdi='cd "$(zoxide query -i)" && eza --tree --level=2 --icons'

# Listing (eza)
alias ls='eza -h --git --icons --group-directories-first'
alias ll='eza -lh --git --icons --color=auto --group-directories-first'
alias la='eza -lha --git --color=auto --group-directories-first'
alias tree='eza --tree --level=2 --git-ignore --icons'

# Git
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gb='git branch'
alias gd='git diff'
alias gco='git checkout'
alias gl='git log --oneline --graph --decorate'

# bat — alias batcat→bat on Debian/Ubuntu; cat stays as cat (no surprises with pager)
if (( $+commands[batcat] )); then
  alias bat='batcat'
  export FZF_DEFAULT_OPTS="--preview '[[ -f {} ]] && batcat --style=numbers --color=always {} | head -100'"
elif (( $+commands[bat] )); then
  export FZF_DEFAULT_OPTS="--preview '[[ -f {} ]] && bat --style=numbers --color=always {} | head -100'"
fi
if (( $+commands[fdfind] )) && ! (( $+commands[fd] )); then
  alias fd='fdfind'
fi
(( $+commands[rg] )) && alias grep='rg'

# chezmoi
alias cma='chezmoi apply'

# Misc
alias fix_exec='find . -type f ! -perm -u=x -exec chmod -x {} +'

# =============================================================================
# Claude Code — perfil work (default é ~/.claude-personal via env var do SO)
# =============================================================================
codew() { CLAUDE_CONFIG_DIR="$HOME/.claude-work" command code "$@"; }

# =============================================================================
# Atualização do sistema — apt + snap + rustup + cargo + fzf
# =============================================================================
update-all() {
  echo "==> apt"
  sudo apt update && sudo apt full-upgrade -y --fix-missing && sudo apt autoremove -y && sudo apt autoclean
  echo "==> snap"
  sudo snap refresh
  if (( $+commands[rustup] )); then
    echo "==> rustup"
    rustup update
  fi
  if (( $+commands[cargo-install-update] )); then
    echo "==> cargo packages"
    cargo install-update -a
  else
    echo "==> cargo packages: pulando (rode 'cargo install cargo-update' uma vez pra habilitar)"
  fi
  if [[ -d ~/.fzf/.git ]]; then
    echo "==> fzf"
    (cd ~/.fzf && git pull --ff-only && ./install --bin)
  fi
  echo "==> done"
}
