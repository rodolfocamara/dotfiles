# Source: dot_config/chezmoi/chezmoi.toml.tmpl
# Target: ~/.config/chezmoi/chezmoi.toml

# sourceDir: opcional override via .chezmoidata.toml (local, gitignored); senão usa o source dir atual
{{- $override := (index . "sourceDirOverride") | default "" }}
sourceDir = "{{ if $override }}{{ $override }}{{ else }}{{ .chezmoi.sourceDir }}{{ end }}"

# --- Encryption (age) ---
encryption = "age"
[age]
# index evita erro quando configDir não existe (versões antigas)
identity = "{{ or (index .chezmoi "configDir") .chezmoi.homeDir }}/.config/chezmoi/age.txt"
# recipient: required for `chezmoi add --encrypt`; get with: age-keygen -y < ~/.config/chezmoi/age.txt
# recipient = "age1xxxxxxxx..."

# --- Windows Specific Mappings ---
# chezmoi v2 does not support arbitrary [ "<target>" ] source = ... blocks
# in its config file. Targets are determined by source path layout: the
# PowerShell profile lives at Documents/PowerShell/Microsoft.PowerShell_profile.ps1
# in the source tree and chezmoi maps it to ~/Documents/PowerShell/...
# automatically. Windows Terminal settings are handled by run_once scripts.

# --- OS-Specific Script Mappings ---
# These scripts will be automatically selected based on OS detection

# Windows package installation
{{ if eq .chezmoi.os "windows" -}}
[ "scripts/install-packages.windows.ps1" ]
    source = "scripts/install-packages.windows.ps1"
    type = "run_once"
    condition = "windows"

{{ else if eq .chezmoi.os "linux" -}}

# Detect Linux distribution for package manager selection
{{ $distro := "unknown" }}
{{ if (stat "/etc/arch-release") }}
    {{ $distro = "arch" }}
{{ else if (stat "/etc/debian_version") }}
    {{ $distro = "debian" }}
{{ else if (stat "/etc/redhat-release") }}
    {{ $distro = "redhat" }}
{{ end }}

# Arch Linux systems (specific package manager)
{{ if eq $distro "arch" -}}
[ "scripts/install-packages.linux-arch.sh" ]
    source = "scripts/install-packages.linux-arch.sh"
    type = "run_once"
    condition = "linux && arch"

{{ else -}}
# Debian-based systems and generic Linux fallback
# This covers: Ubuntu, Debian, Mint, Pop!_OS, and other apt-based distros
[ "scripts/install-packages.linux-generic.sh" ]
    source = "scripts/install-packages.linux-generic.sh"
    type = "run_once"
    condition = "linux"

{{ end -}}
{{ end -}}

# --- Interpreters ---
[interpreters]
{{ if eq .chezmoi.os "windows" -}}
  [interpreters.ps1]
    command = "powershell.exe"
    args = ["-NoProfile", "-NoLogo", "-ExecutionPolicy", "Bypass", "-File"]
  [interpreters.sh]
    command = "bash.exe"
    args = ["-eu", "-o", "pipefail"]
{{ else -}}
  # Linux/macOS: .sh com /bin/bash (evita bash.exe em WSL ou config antigo)
  [interpreters.sh]
    command = "/bin/bash"
    args = ["-eu", "-o", "pipefail"]
{{ end -}}

# --- Targets para /etc (apply com: sudo chezmoi apply -v) ---
[ "etc/openvpn/scripts/executable_dns-up.sh" ]
  target = "/etc/openvpn/scripts/dns-up.sh"
[ "etc/openvpn/scripts/executable_dns-down.sh" ]
  target = "/etc/openvpn/scripts/dns-down.sh"
[ "etc/polkit-1/rules.d/49-openvpn-resolved.rules" ]
  target = "/etc/polkit-1/rules.d/49-openvpn-resolved.rules"
[ "etc/openvpn/client/encrypted_client.conf.age" ]
  target = "/etc/openvpn/client/client.conf"

# --- General chezmoi settings can go here ---
# Example: Use VS Code for editing
# [edit]
#   command = "code"
#   args = ["--wait"]

# Add other settings as needed (e.g., encryption, git config)
