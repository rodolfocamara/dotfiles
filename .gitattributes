# Default: detect text vs binary, normalize text to LF on commit + checkout.
* text=auto eol=lf

# Windows-only files keep CRLF (PowerShell, batch, registry).
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.reg text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
*.age binary
