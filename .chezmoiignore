# Standard ignored files/folders
README.md

# Never create these in ~ (repo structure only)
docs/
packages/
scripts/
home/

# Ignore Windows-only directories on Linux/macOS.
{{ if ne .chezmoi.os "windows" }}
apps/
Documents/
{{ end }}

# Ignore Linux-specific scripts on Windows
{{ if eq .chezmoi.os "windows" }}
.chezmoiscripts/**/*.sh.tmpl
{{ end }}

# Ignore Windows-specific scripts on Linux/macOS
# Ignore Windows-only content on Linux/macOS
{{ if ne .chezmoi.os "windows" }}
.chezmoiscripts/**/*.ps1.tmpl
scripts/install-packages.windows.ps1
# Windows-only codex shim (.cmd); the bash wrapper handles WSL/Linux.
.local/bin/codex.cmd
{{ end }}

# Ignore Linux-only targets on Windows. No /etc, no age key, and the
# desktop/shell configs (Hyprland, Waybar, Wofi, Kitty, direnv, zsh)
# have no meaningful Windows target. zsh runs inside WSL, which chezmoi
# sees as Linux.
{{ if eq .chezmoi.os "windows" }}
etc/
.config/hypr/
.config/waybar/
.config/wofi/
.config/kitty/
.config/direnv/
.envrc
.zshenv
.zshrc
# apps/windows_terminal/ has no active chezmoi mapping (Windows Terminal
# settings are managed by run_once scripts, not chezmoi targets).
apps/windows_terminal/
# Linux-only run-after script (chmods /etc/openvpn/client/); no-op on
# Windows but would still appear in `chezmoi status` on every apply.
# .chezmoiignore matches the target name (without the run_after_ prefix).
openvpn_client_permissions.sh
# The codex bash wrapper is WSL/Linux-only; Windows uses codex.cmd instead.
.local/bin/codex
{{ end }}

# Reject plaintext OpenVPN client config (only encrypted_client.conf.age is allowed)
etc/openvpn/client/client.conf
# Keep dir in git but do not apply .gitkeep to /etc
etc/openvpn/client/.gitkeep

# Skip the OpenVPN client perms script on WSL (no native /etc/openvpn use there).
{{ if and (ne .chezmoi.os "windows") (contains "microsoft" (lower (or .chezmoi.kernel.osrelease ""))) }}
openvpn_client_permissions.sh
{{ end }}